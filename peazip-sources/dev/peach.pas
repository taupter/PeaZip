procedure populate_archive;
var
   i,j,k,lstrt:integer;
   nodefound,nodenotfinalized:boolean;
   strt:AnsiString;
begin
//tree view archive representation, maxed to maxndirtree number of dirs for performances
FormPeach.TreeViewNav.Items.Beginupdate;

if (FormPeach.StringGridAddressAllFolders.RowCount=1) and (FormPeach.StringGridAddressOmittedFolders.RowCount=1) then
   begin
   FormPeach.TreeViewNav.Items.Clear;
   exit;
   end;

if fun='UN7Z' then
   if (status1=txt_list_nomatch+txt_2_7_list_tryflatorpw) or (browse_option='l') then
      begin
      FormPeach.TreeViewNav.Items.Clear;
      exit;
      end
   else
else
   begin
   FormPeach.TreeViewNav.Items.Clear;
   exit;
   end;

if set_archivetree=false then
   begin
   if extractfilename(FormPeach.EditOpenIn.Text)='' then
      begin
      FormPeach.TreeViewNav.Items.Clear;
      end
   else
      begin
      if FormPeach.StringGridAddressAllFolders.rowcount>maxndirtree then
         for i:=FormPeach.TreeViewNav.Items.Count-1 downto 2 do FormPeach.TreeViewNav.Items[i].Delete
      else
         for i:=FormPeach.TreeViewNav.Items.Count-1 downto FormPeach.StringGridAddressAllFolders.RowCount+1 do FormPeach.TreeViewNav.Items[i].Delete;
      end;
   exit;
   end
else set_archivetree:=false;

FormPeach.TreeViewNav.Items.Clear;
if extractfilename(FormPeach.EditOpenInInteractive.Text)='' then exit;

with FormPeach.TreeViewNav.Items.Add(nil,extractfilename(FormPeach.EditOpenInInteractive.Text)) do
   begin
   Selected:=true;
   ImageIndex:=geticon(FormPeach.EditOpenInInteractive.Text,ExtractFileExt(FormPeach.EditOpenInInteractive.Text),false);
   SelectedIndex:=ImageIndex;
   end;

if (FormPeach.StringGridAddressAllFolders.rowcount<2) or (FormPeach.StringGridAddressAllFolders.rowcount>maxndirtree) then
   begin
   FormPeach.TreeViewNav.Items.Add(nil,'');
   exit;
   end;

if FormPeach.StringGridAddressAllFolders.Cells[12,1]='' then
   begin
   FormPeach.TreeViewNav.Items.Add(nil,'');
   exit;
   end;

FormPeach.StringGridAddressAllFolders.Beginupdate;
FormPeach.StringGridAddressAllFolders.SortColRow(true,12);
with FormPeach.TreeViewNav.Items.AddChild(FormPeach.TreeViewNav.selected,FormPeach.StringGridAddressAllFolders.Cells[12,1]) do
   begin
   FormPeach.StringGridAddressAllFolders.Cells[13,1]:='1';
   Selected:=true;
   ImageIndex:=3;
   SelectedIndex:=3;
   end;
FormPeach.TreeViewNav.BeginUpdate;
FormPeach.TreeViewNav.visible:=false;
for i:=2 to FormPeach.StringGridAddressAllFolders.RowCount-1 do
   begin
   nodefound:=false;
   if FormPeach.StringGridAddressAllFolders.Cells[12,i]<>FormPeach.StringGridAddressAllFolders.Cells[12,i-1] then
      begin
      strt:=FormPeach.StringGridAddressAllFolders.Cells[12,i]+directoryseparator;
      lstrt:=length(FormPeach.StringGridAddressAllFolders.Cells[12,i]);
      for j:=1 to FormPeach.TreeViewNav.Items.Count-1 do
         begin
         if (lstrt>length(FormPeach.TreeViewNav.Items[j].Text)) and
            (posex(FormPeach.TreeViewNav.Items[j].Text+directoryseparator,strt,1)=1) then
            begin
            nodenotfinalized:=false;
            for k:=j+1 to FormPeach.TreeViewNav.Items.Count-1 do
               begin
               if (lstrt>length(FormPeach.TreeViewNav.Items[k].Text)) and
                  (posex(FormPeach.TreeViewNav.Items[k].Text+directoryseparator,strt,1)=1) then
                  begin
                  nodenotfinalized:=true;
                  break;
                  end;
               end;
            if nodenotfinalized=false then
               with FormPeach.TreeViewNav.Items.AddChild(FormPeach.TreeViewNav.Items[j],FormPeach.StringGridAddressAllFolders.Cells[12,i]) do
                  begin
                  Selected:=true;
                  ImageIndex:=3;
                  SelectedIndex:=3;
                  nodefound:=true;
                  break;
                  end;
            end;
         end;
      end
   else nodefound:=true; //discard possible duplicates for same dir
   if nodefound=false then
      with FormPeach.TreeViewNav.Items.AddChild(FormPeach.TreeViewNav.Items[0],FormPeach.StringGridAddressAllFolders.Cells[12,i]) do
         begin
         Selected:=true;
         ImageIndex:=3;
         SelectedIndex:=3;
         end;
   end;
FormPeach.TreeViewNav.EndUpdate;
FormPeach.TreeViewNav.visible:=true;
FormPeach.StringGridAddressAllFolders.clear;
FormPeach.StringGridAddressAllFolders.rowcount:=FormPeach.TreeViewNav.Items.Count;
for i:=1 to FormPeach.TreeViewNav.Items.Count-1 do
   FormPeach.StringGridAddressAllFolders.Cells[12,i]:=FormPeach.TreeViewNav.Items[i].text;
for j:=1 to FormPeach.TreeViewNav.Items.Count-1 do
   FormPeach.TreeViewNav.Items[j].Text:=dirextractfilename(FormPeach.TreeViewNav.Items[j].Text);
FormPeach.StringGridAddressAllFolders.EndUpdate;

FormPeach.TreeViewNav.Selected:=FormPeach.TreeViewNav.Items[0];
FormPeach.TreeViewNav.Selected.collapse(true);
aisexpanded:=false;

FormPeach.TreeViewNav.Items.Add(nil,'');

end;

begin
with FormPeach do
begin

populate_archive;

populate_bookmarks;

TreeViewNav.Items.Add(nil,'');
with TreeViewNav.Items.Add(nil,txt_fs) do
   begin
   Selected:=true;
