   begin
   try inpath:=extractfilepath(FormPeach.EditUn7zaFilter.Text); except inpath:=''; end;//allow adding to empty folders
   end
else
   inpath:='';

//if isabspath(inpath) then exit;

if inpath<>'' then
   begin
   s:=FormPeach.EditOpenIn.Text;
   fextl:=upcase(extractfileext(s));
   if (fextl='.7Z') or (fextl='.TAR') or (fextl='.ZIP') or (fextl='.WIM') or (fextl='.RAR') or (test_forceeditunsupported(s)=1) then
