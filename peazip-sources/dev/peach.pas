procedure previewinternal; //if first selected item is a text use text preview, else use image preview, on the entire list of selected items
var
   i:integer;
begin
if FormPeach.StringGridList.RowCount<2 then exit;
if FormPeach.StringGridList.Cells[1,1]='' then exit;
for i:=1 to FormPeach.StringGridList.RowCount-1 do
   if FormPeach.StringGridList.Cells[16,i]='1' then
      if istexttype(FormPeach.StringGridList.Cells[2,i])=true then
         begin
         hexpselected_list('TEXTPREVIEW');
         exit;
         end;
viewimageloop;
end;

procedure TFormPeach.MenuItemViewImageClick(Sender: TObject);
