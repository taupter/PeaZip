procedure TFormPeach.ListViewBrowserMouseMove(Sender: TObject; Shift: TShiftState;
  X, Y: Integer);
var
   p:TPoint;
   i:integer;
   s:ansistring;
begin
if shift=[ssLeft] then wasselected:=-1;
pclicked:=false;
{$IFDEF MSWINDOWS}
if nativedrag=1 then
   disdrag:=false;
{$ENDIF}
if openstarted=false then exit;
if checkboxshowhints.Checked=false then exit;

if ListViewBrowser.ViewStyle=vsReport then
   if x>=col1size then
      begin
      shint:='';
      prevshint:='';
      try
      h.hide;
      except
      end;
      exit;
      end;

s:='';
try
if ListViewBrowser.GetItemAt(x,y)<>nil then i:=ListViewBrowser.GetItemAt(x,y).Index else
   begin
   shint:=s;
   exit;
   end;
if i>-1 then
  begin
  if ListViewBrowser.Items[i].Caption<>'' then
     begin
     s:=ListViewBrowser.Items[i].Caption;
     if ListViewBrowser.Items[i].SubItems[0]<>'' then s:=s+char($0D)+char($0A)+ListViewBrowser.Column[1].Caption+' - '+ListViewBrowser.Items[i].SubItems[0];
     if ListViewBrowser.Items[i].SubItems[0]=txt_list_isfolder then
        begin
        if ListViewBrowser.Items[i].SubItems[9]<>'' then s:=s+char($0D)+char($0A)+txt_content+' - '+ListViewBrowser.Items[i].SubItems[9];
        end
     else
        begin
        if ListViewBrowser.Items[i].SubItems[1]<>'' then s:=s+char($0D)+char($0A)+ListViewBrowser.Column[2].Caption+' - '+ListViewBrowser.Items[i].SubItems[1];
        if ListViewBrowser.Items[i].SubItems[2]<>'' then
           case ListViewBrowser.Items[i].SubItems[2] of
           '.': s:=s+char($0D)+char($0A)+ListViewBrowser.Column[3].Caption+' - '+txt_6_2_container;
           '+': s:=s+char($0D)+char($0A)+ListViewBrowser.Column[3].Caption+' - '+txt_6_2_archive;
           else
              s:=s+char($0D)+char($0A)+ListViewBrowser.Column[3].Caption+' - '+ListViewBrowser.Items[i].SubItems[2];
           end;
        if ListViewBrowser.Items[i].SubItems[9]<>'' then s:=s+char($0D)+char($0A)+ListViewBrowser.Column[10].Caption+' - '+ListViewBrowser.Items[i].SubItems[9];
        end;
     if ListViewBrowser.Items[i].SubItems[6]<>'' then s:=s+char($0D)+char($0A)+ListViewBrowser.Column[7].Caption+' - '+ListViewBrowser.Items[i].SubItems[6];
     if ListViewBrowser.Items[i].SubItems[8]<>'' then s:=s+char($0D)+char($0A)+ListViewBrowser.Column[9].Caption+' - '+ListViewBrowser.Items[i].SubItems[8];
     if ListViewBrowser.Items[i].SubItems[3]<>'' then s:=s+char($0D)+char($0A)+ListViewBrowser.Column[4].Caption+' - '+ListViewBrowser.Items[i].SubItems[3];
     if ListViewBrowser.Items[i].SubItems[4]<>'' then s:=s+char($0D)+char($0A)+ListViewBrowser.Column[5].Caption+' - '+ListViewBrowser.Items[i].SubItems[4];
     if ListViewBrowser.Items[i].SubItems[5]<>'' then s:=s+char($0D)+char($0A)+ListViewBrowser.Column[6].Caption+' - '+ListViewBrowser.Items[i].SubItems[5];
     if ListViewBrowser.Items[i].SubItems[7]<>'' then s:=s+char($0D)+char($0A)+ListViewBrowser.Column[8].Caption+' - '+ListViewBrowser.Items[i].SubItems[7];
     if status0<>txt_list_browsing then
        if ListViewBrowser.Items[i].SubItems[10]<>'' then
           if extractfilepath(ListViewBrowser.Items[i].SubItems[10])<>'' then s:=s+char($0D)+char($0A)+txt_path+' - '+extractfilepath(ListViewBrowser.Items[i].SubItems[10]);
     end;
  end
else
   begin
   shint:=s;
   exit;
   end;
except
shint:=s;
exit;
end;
if s='' then
   begin
   shint:=s;
   exit;
   end;
if s<>shint then
try
   h.hide;
except
end;
p.x:=x;
p.y:=y;
p.x:=p.x+ListViewBrowser.left;//SplitterSide.left;
p.y:=p.y+panelfilters.top+19;
p:=clienttoscreen(p);
r.Left := p.x; //or the absolute left position of the control
r.Top := p.y; //or the absolute top position of the control
r.right:=r.left+h.CalcHintRect(320,s,nil).right;
r.bottom:=r.top+h.CalcHintRect(320,s,nil).bottom;
shint:=s;
end;

procedure TFormPeach.ListViewBrowserSelectItem(Sender: TObject; Item: TListItem;//on macOS (Laz 4.2) seems the listview selectitem event is not triggered if ownerdata is changed from true to flase at runtime (leaving virtual mode); runs ok on other widgetset
  Selected: Boolean);
var
   i,rc:integer;
begin //(Lazarus 4.x) the event is always triggered on macOS after content update; on some other widgetsets it is triggered if prebrowsing is enabled
if updatinglistview=true then exit;
if browserbusy=true then exit;
if updatingsel=true then exit;
updatingsel:=true;
{$IFDEF MSWINDOWS} //select item is raised to uncheck each selected object and check each new one, so for an iteration it is enough to ScheduleAdd one change of state in the underlying stringgrid
if ListViewBrowser.OwnerData=false then
   begin//good speed, does not work with listview in virtual mode
   i:=Item.index+1;
   if ListViewBrowser.Items[i-1].Selected<>true then StringGridList.Cells[16,i]:='0' else StringGridList.Cells[16,i]:='1';
   end
else
   begin//little slow, tested on Laz 4.2, event is repeated for each selected item incrementing each time the selected items count
   StringGridList.BeginUpdate;
   rc:=StringGridList.Rowcount;
   for i:=1 to rc-1 do
      if ListViewBrowser.Items[i-1].Selected<>true then
         StringGridList.Cells[16,i]:='0'
      else
         StringGridList.Cells[16,i]:='1';
   StringGridList.EndUpdate;
   end;
{$ELSE} //method based on selected item doesn't work on Qt, nor for virtual mode on some widgetsets, making necessary to update the entire grid
{$IFDEF LCLQT6}//very slow on Qt6, tested on Laz 4.2, event is repeated for each selected item for the same total of selected items count; following workaround stops after few cycles (new selection changes the selected items count)
curselcount:=FormPeach.ListViewBrowser.SelCount;
if curselcount>8 then
   if curselcount=prevselcount then
      begin
      wasselected:=-1;
      updatingsel:=false;
      exit;
      end;
{$ENDIF}
StringGridList.BeginUpdate;//acceptable speed on GTK2, tested on Laz 4.2, event is repeated for each selected item for the same total of selected items count
rc:=StringGridList.Rowcount;
for i:=1 to rc-1 do
   if ListViewBrowser.Items[i-1].Selected<>true then
      StringGridList.Cells[16,i]:='0'
   else
      StringGridList.Cells[16,i]:='1';
StringGridList.EndUpdate;
{$IFDEF LCLQT6}
prevselcount:=curselcount;
{$ENDIF}
{$ENDIF}
//set_grid; //Lazarus 0.9.30: no longer needed, selection is always updated before action is launched
//update_selstatus; //now associated to onmouseup and onkeyup
if FormPeach.ListViewBrowser.SelCount>1 then wasselected:=-1;
updatingsel:=false;
end;

