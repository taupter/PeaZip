{
//possible implementation rename in place by editing listview
procedure renameinplace(s:ansistring);
var
   i:integer;
   namecollisionfound:boolean;
begin
if (fun<>'FILEBROWSER') and (fun<>'UN7Z') then exit;
{$IFDEF MSWINDOWS}if FormPeach.EditOpenIn.Text=txt_mypc then exit;{$ENDIF}
if FormPeach.StringGridList.RowCount<2 then exit;
if FormPeach.StringGridList.Cells[1,1]='' then exit;
if checkfilename(s)<>0 then
   begin
   pMessageWarningOK('"'+s+'" '+txt_checkname_failed+char($0D)+char($0A)+txt_name_provide);
   exit;
   end;
enter_busy_status;
namecollisionfound:=false;
if fun='UN7Z' then
   for i:=1 to FormPeach.StringGridArchive.Rowcount-1 do
      if FormPeach.StringGridArchive.Cells[12,i]=extractfilepath(FormPeach.StringGridList.Cells[12,FormPeach.StringGridList.Row])+s then
         begin
         namecollisionfound:=true;
         break;
         end;
if namecollisionfound=true then
   if pMessageInfoYesNo(txt_6_9_overarch)=7 then
      begin
      exit_busy_status;
      exit;
      end;
if fun='FILEBROWSER' then renamefile(FormPeach.StringGridList.Cells[12,FormPeach.StringGridList.Row],extractfilepath(FormPeach.StringGridList.Cells[12,FormPeach.StringGridList.Row])+s);
if fun='UN7Z' then renamefileinarchive(FormPeach.StringGridList.Cells[12,FormPeach.StringGridList.Row],extractfilepath(FormPeach.StringGridList.Cells[12,FormPeach.StringGridList.Row])+s,true);
exit_busy_status;
end;
}

procedure TFormPeach.ListViewBrowserEdited(Sender: TObject; Item: TListItem;
  var AValue: string);
begin
{
//possible implementation rename in place by editing listview
{$IFDEF MSWINDOWS}
//does not fully work on all systems as for Lazarus 4.x (seem not working at least on macos)
FormPeach.ListViewBrowser.ReadOnly:=true;
if FormPeach.EditOpenIn.Text<>renorig then
   begin //crashes with access violation on some instances e.g. go up so browser needs to be in busy status
   FormPeach.ListViewBrowser.Selected:=nil;
   wasselected:=-1;
   exit_busy_status;
   exit;
   end;
if item.Caption=avalue then
   begin
   FormPeach.ListViewBrowser.Selected:=nil;
   wasselected:=-1;
   exit_busy_status;
   exit;
   end;
renameinplace(avalue);
//refresh needs to be trigger async as listview editing is fully completed (otherwise crashes refreshing in archives)
//mouse selection is triggered in error after the operation if editor is closed by clicking outside
Timerrename1.enabled:=true;
{$ENDIF}
}
end;

