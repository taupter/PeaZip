procedure list_toextractor(act,modeofuse:ansistring);
var
   i,j,rc,c,d,k:integer;
   okfile,checksel,allselected:boolean;
   exp_files:TFoundList;
   exp_fsizes:TFoundListSizes;
   exp_ftimes:TFoundListAges;
   exp_fattr:TFoundListAttrib;
   exp_fattr_dec:TFoundList;
   nfound,mpsize:qword;
begin
FormPeach.LabelGoExtract.Caption:='';
FormPeach.CheckBoxDeleteInputExt.Enabled:=true;
FormPeach.cbDeleteInputModeExt.Enabled:=true;
FormPeach.CheckBoxDeleteInputExt.Hint:='';
resetminimizedlauncher;
extselall:=false;
if (FormPeach.EditOpenIn.Caption=FormPeach.EditOpenInInteractive.Caption) and //no display filters
   (FormAdvf.CheckBoxAdvFilters.State=cbUnchecked) then //no advanced filters
   begin
   if act='selected' then
      if checklistanysel<>0 then act:='displayed';
   if act='selected' then
      begin
      allselected:=true;
      rc:=FormPeach.StringGridList.RowCount;
      for i:=1 to rc-1 do
         if FormPeach.StringGridList.Cells[16,i]='0' then
            begin
            allselected:=false;
            Break;
            end;
      if allselected=true then act:='displayed';
      end;
   if act='displayed' then
      if FormPeach.EditUn7zaFilterInteractive.Caption='*' then act:='all';
   end;
case act of
   'multi' :
   begin
   extsel:='all';
   setextpopupmenu('1');
   FormPeach.StringGridExtract.Hint:=txt_2_7_exthint;
   FormPeach.LabelStatusExtract.Caption:=txt_2_7_ext;
   FormPeach.LabelStatusExDetails.Hint:='';
   rc:=FormPeach.StringGridList.RowCount;
   k:=FormPeach.StringGridExtract.RowCount;
   for i:=1 to rc-1 do
      if FormPeach.StringGridList.Cells[16,i]='1' then
         if FormPeach.StringGridList.Cells[2,i]<>txt_list_isfolder then  //files
            begin
            test_extfile(FormPeach.StringGridList.Cells[12,i],okfile);
            if okfile=true then
               begin
               if checkfiledirname(FormPeach.StringGridList.Cells[12,i])<>0 then begin pMessageWarningOK(txt_2_7_validatefn+' '+FormPeach.StringGridList.Cells[12,i]); exit; end;
               FormPeach.StringGridExtract.RowCount:=k+1;
               for c:=1 to 13 do
                 begin
                 if c<6 then d:=c else d:=c+3;
                 if d>=9 then d:=d+1;
                 FormPeach.StringGridExtract.Cells[c,k]:=FormPeach.StringGridList.Cells[d,i];
                 end;
               FormPeach.StringGridExtract.Cells[12,k]:=FormPeach.StringGridList.Cells[3,i];
               if fun='FILEBROWSER' then //get correct size for multipart archives
                  begin
                  srcfilesize_multipart(FormPeach.StringGridList.Cells[12,i],mpsize);
                  FormPeach.StringGridExtract.Cells[12,k]:=IntToStr(mpsize);
                  end;
               FormPeach.StringGridExtract.Cells[3,k]:=nicenumber(FormPeach.StringGridExtract.Cells[12,k],filesizebase);
               if FormPeach.StringGridExtract.Cells[4,k]<>'' then FormPeach.StringGridExtract.Cells[4,k]:=nicenumber(FormPeach.StringGridExtract.Cells[4,k],filesizebase);
               k:=k+1;
               end;
            end
         else //folders (expand recursively)
            begin
            expand(FormPeach.StringGridList.Cells[12,i],exp_files,exp_fsizes,exp_ftimes,exp_fattr,exp_fattr_dec,nfound);
            for j:=0 to nfound-1 do
               if pos('D',exp_fattr_dec[j])=0 then
                  begin
                  test_extfile(exp_files[j],okfile);
                  if okfile=true then
                     begin
                     if checkfiledirname(exp_files[j])<>0 then begin pMessageWarningOK(txt_2_7_validatefn+' '+exp_files[j]); exit; end;
                     FormPeach.StringGridExtract.RowCount:=k+1;
                     FormPeach.StringGridExtract.Cells[8,k]:=exp_files[j];
                     FormPeach.StringGridExtract.Cells[1,k]:=extractfilename(exp_files[j]);
                     FormPeach.StringGridExtract.Cells[9,k]:=prefixf+FormPeach.StringGridExtract.Cells[1,k];
                     FormPeach.StringGridExtract.Cells[2,k]:=ExtractFileExt(exp_files[j]);
                     FormPeach.StringGridExtract.Cells[12,k]:=inttostr(exp_fsizes[j]);
                     if fun='FILEBROWSER' then //get correct size for multipart archives
                        begin
                        srcfilesize_multipart(exp_files[j],mpsize);
                        FormPeach.StringGridExtract.Cells[12,k]:=IntToStr(mpsize);
                        end;
                     FormPeach.StringGridExtract.Cells[3,k]:=nicenumber(FormPeach.StringGridExtract.Cells[12,k],filesizebase);
                     if testext((exp_files[j]))>=0 then
                        if (testext((exp_files[j]))>=500) and (testext((exp_files[j]))<=503) then
                           FormPeach.StringGridExtract.Cells[4,k]:='.'
                        else
                            FormPeach.StringGridExtract.Cells[4,k]:='+';
                     FormPeach.StringGridExtract.Cells[5,k]:=FormatDateTime('yyyy-mm-dd hh:mm:ss', filedatetodatetime(exp_ftimes[j]));
                     FormPeach.StringGridExtract.Cells[6,k]:=exp_fattr_dec[j];
                     FormPeach.StringGridExtract.Cells[10,k]:=inttostr(length(inttostr(length(FormPeach.StringGridExtract.Cells[3,k]))))+inttostr(length(FormPeach.StringGridExtract.Cells[3,k]))+FormPeach.StringGridExtract.Cells[3,k];
                     FormPeach.StringGridExtract.Cells[11,k]:=FormPeach.StringGridExtract.Cells[4,k];
                     k:=k+1;
                     end;
                  end;
            end;
   FormPeach.StringGridExtract.RowCount:=k;
   updatecontent_ext;
   end;
   'none' :
   begin
   extsel:='all';
   FormPeach.StringGridExtract.popupmenu:=FormPeach.popuplayout;
   FormPeach.StringGridExtract.Hint:=txt_2_7_exthint;
   FormPeach.LabelStatusExtract.Caption:=txt_2_7_ext;
   FormPeach.LabelStatusExDetails.Hint:='';
   updatecontent_ext;
   end;
   'all' :
   begin
   extsel:=act;
   extselall:=true;
   setextpopupmenu('2');
   FormPeach.StringGridExtract.Hint:='';
   FormPeach.LabelStatusExtract.Caption:=txt_2_7_extfrom+' '+FormPeach.EditOpenIn.Text;
   FormPeach.LabelStatusExDetails.Hint:='';
   FormPeach.StringGridExtract.RowCount:=1;//clean previous records
   FormPeach.StringGridExtract.RowCount:=2;
   FormPeach.StringGridExtract.Cells[1,1]:='('+txt_all+')';
   autosize_stringgrid2;
   updatecontent_ext;
   end;
   'displayed' :
   begin
   setstatus5;
   extsel:=act;
   setextpopupmenu('2');
   FormPeach.StringGridExtract.Hint:='';
   FormPeach.LabelStatusExtract.Caption:=txt_2_7_extfrom+' '+FormPeach.EditOpenIn.Text;
   FormPeach.LabelStatusExDetails.Hint:=txt_2_7_dirsize;
   rc:=FormPeach.StringGridList.RowCount;
   FormPeach.StringGridExtract.RowCount:=rc;
   k:=1;
   for i:=1 to rc-1 do
      begin
      if checkfiledirname(FormPeach.StringGridList.Cells[12,i])<>0 then begin pMessageWarningOK(txt_2_7_validatefn+' '+FormPeach.StringGridList.Cells[12,i]); exit; end;
      FormPeach.StringGridExtract.RowCount:=k+1;
      for c:=1 to 13 do
        begin
        if c<6 then d:=c else d:=c+3;
        if d>=9 then d:=d+1;
        FormPeach.StringGridExtract.Cells[c,k]:=FormPeach.StringGridList.Cells[d,i];
        end;
      FormPeach.StringGridExtract.Cells[12,k]:=FormPeach.StringGridList.Cells[3,i];
      FormPeach.StringGridExtract.Cells[3,k]:=nicenumber(FormPeach.StringGridExtract.Cells[12,k],filesizebase);
      if FormPeach.StringGridExtract.Cells[4,k]<>'' then FormPeach.StringGridExtract.Cells[4,k]:=nicenumber(FormPeach.StringGridExtract.Cells[4,k],filesizebase);
      k:=k+1;
      end;
   FormPeach.StringGridExtract.RowCount:=k;
   updatecontent_ext;
   end;
   'selected' :
   begin
   setstatus5;
   extsel:=act;
   checksel:=false;
   setextpopupmenu('2');
   FormPeach.StringGridExtract.Hint:='';
   FormPeach.LabelStatusExtract.Caption:=txt_2_7_extfrom+' '+FormPeach.EditOpenIn.Text;
   FormPeach.LabelStatusExDetails.Hint:=txt_2_7_dirsize;
   rc:=FormPeach.StringGridList.RowCount;
   FormPeach.StringGridExtract.RowCount:=rc;
   k:=1;
   for i:=1 to rc-1 do
      if FormPeach.StringGridList.Cells[16,i]='1' then
         begin
         if checkfiledirname(FormPeach.StringGridList.Cells[12,i])<>0 then begin pMessageWarningOK(txt_2_7_validatefn+' '+FormPeach.StringGridList.Cells[12,i]); exit; end;
         FormPeach.StringGridExtract.RowCount:=k+1;
         for c:=1 to 13 do
            begin
            if c<6 then d:=c else d:=c+3;
            if d>=9 then d:=d+1;
            FormPeach.StringGridExtract.Cells[c,k]:=FormPeach.StringGridList.Cells[d,i];
            end;
         FormPeach.StringGridExtract.Cells[12,k]:=FormPeach.StringGridList.Cells[3,i];
         FormPeach.StringGridExtract.Cells[3,k]:=nicenumber(FormPeach.StringGridExtract.Cells[12,k],filesizebase);
         if FormPeach.StringGridExtract.Cells[4,k]<>'' then FormPeach.StringGridExtract.Cells[4,k]:=nicenumber(FormPeach.StringGridExtract.Cells[4,k],filesizebase);
         k:=k+1;
         checksel:=true;
         end;
   FormPeach.StringGridExtract.RowCount:=k;
   updatecontent_ext;
   if checksel=false then exit;
   end;
   end;
if FormPeach.StringGridExtract.RowCount>1 then
   begin
   FormPeach.StringGridExtract.Cells[11,1]:='1';
   FormPeach.StringGridExtract.Row:=1;
   end;
if modeofuse='full' then showpanel('extract');
end;

procedure do_extract;
begin
{$IFDEF MSWINDOWS}
if FormPeach.EditOpenIn.Text=txt_mypc then
   begin
   list_toextractor('none','full');
   exit;
   end;
{$ENDIF}
if FormPeach.StringGridList.RowCount<2 then exit;
if FormPeach.StringGridList.Cells[1,1]='' then
   begin
   if fun='FILEBROWSER' then
      list_toextractor('none','full')
   else
      if intpw=1 then list_toextractor('all','full');
   exit;
   end;
if fun='FILEBROWSER' then list_toextractor('multi','full')
else
   if FormPeach.menuitemopen_extracthere.visible=false then list_toextractor('all','full') //if partial extraction is not supported, the selection is automatically overridden
   else
      if checklistanysel=0 then list_toextractor('selected','full')
      else list_toextractor('displayed','full'); //as in WinRar/7-Zip, if nothing is selected extract all currently displayed content
end;

