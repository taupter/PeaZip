if (selfolders=0) and (selfiles=0) then FormPeach.LabelStatus.Caption:='';
if FormPeach.LabelStatus.Caption<>'' then FormPeach.LabelStatus.Visible:=true else FormPeach.LabelStatus.Visible:=false;
end;

