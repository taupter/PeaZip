      begin
      cutextension(s);
      if lowercase(extractfileext(s))='.tar' then cutextension(s);
      end;
   EditAddFilepath.Text:=extractfilepath(s);
   if checkboxseparate.state=cbUnchecked then EditAddFilename.Text:=extractfilename(s);
   end;
get_statuss(FormPeach.EditAddName.Text);
FormPeach.labelstatusAr.Visible:=false;
