sort_az_stringgridlist_special(listsortcol);
if (lastobj='') or (lastobj=txt_mypc) then lastobj:='C:\'; //(will skip to first drive if specified drive is not found) possible customization: select by default system drive, or user selected drive, etc...
set_lastobjpc;
if sizetotal<>0 then i:=(sizefree*100) div sizetotal;
statust:=inttostr(FormPeach.StringGridList.Rowcount-1)+' '+txt_units+'; '+nicenumber(inttostr(sizetotal),filesizebase)+', '+nicenumber(inttostr(sizefree),filesizebase)+' '+txt_free2+' ('+inttostr(i)+'%)';
update_listview;
FormPeach.Caption:=txt_mypc;
indir:=txt_mypc;
prevarchive:='';
listingdir:=false;
{$ENDIF}
end;

procedure savecol;
begin
if (FormPeach.mroot.Caption='<ROOT>') and (FormPeach.mroot.Visible=false) then exit; //avoid until form is fully ready
if (browsertype=0) and (FormPeach.EditOpenIn.Caption<>txt_mypc) and (frompc=false) then
   begin
   if FormPeach.ListViewBrowser.Column[0].Width>0 then col1size:=FormPeach.ListViewBrowser.Column[0].Width;
   if ctype=false then else col2size:=FormPeach.ListViewBrowser.Column[1].Width;
   if csize=false then else col3size:=FormPeach.ListViewBrowser.Column[2].Width;
   if cpacked=false then else col4size:=FormPeach.ListViewBrowser.Column[3].Width;
   if cdate=false then else col5size:=FormPeach.ListViewBrowser.Column[4].Width;
   if catt=false then else col6size:=FormPeach.ListViewBrowser.Column[9].Width;
   if ccrc=false then else col7size:=FormPeach.ListViewBrowser.Column[10].Width;
   end;
end;

function setpcmenuicon(i:integer):TBitmap;
begin
case i of
   1: setpcmenuicon:=Bfd_supported;
   2: setpcmenuicon:=Bremovable_supported;
   3: setpcmenuicon:=Bhd_supported;
   4: setpcmenuicon:=Bremote_supported;
   5: setpcmenuicon:=Bdvd_supported;
   6: setpcmenuicon:=Bram_supported;
   else setpcmenuicon:=nil;
   end;
end;

procedure countunits(var nunits:qword);
var
   s:ansistring;
   i:qword;
   drivestr:array[1..255] of word;
begin
{$IFDEF MSWINDOWS}
if countingunits=true then
   begin
   FormPeach.TimerBrowser.enabled:=false; //stop auto-checking units count if it's taking an unusual amount of time (reset on refresh or browse dir)
   exit;
   end;
countingunits:=true;
GetLogicalDriveStringsW(255,@drivestr);
i:=1;
nunits:=0;
repeat
   s:='';
   nunits:=nunits+1;
   while (i<=255) and (drivestr[i]<>0) do
      begin
      s:=s+char(drivestr[i]);
      inc(i);
      end;
   inc(i);
until length(s)=0;
nunits:=nunits-1;
countingunits:=false;
{$ENDIF}
end;

procedure copyunitmenu(a:TMenuItem; var b:TMenuItem);
begin
b.Visible:=a.Visible;
b.Caption:=a.Caption;
b.Bitmap:=a.Bitmap;
end;

procedure populatepcmenu;
{$IFDEF MSWINDOWS}
var
   s,s1,dtype,dname,uncname:ansistring;
   w:widestring;
   n:byte;
   c:char;
   sz:int64;
   i,j,k,t:qword;
   sn,mc,flags:dword;
   bufVolumeName,bufFSName: array[0..255] of WChar;
   ws:widestring;
   drivestr:array[1..255] of word;
   tsin,tsout:TTimeStamp;
   tdiff:qword;
   ErrorMode: Word;
   {$ENDIF}
begin
{$IFDEF MSWINDOWS}
GetLogicalDriveStringsW(255,@drivestr);
for n:=1 to 26 do devname[n]:='';
try
i:=1;
j:=1;
k:=0;
tsin:=datetimetotimestamp(now);
repeat
   s:='';
   dtype:='';
   dname:='';
   uncname:='';
   bufVolumeName:='';
   k:=k+1;
   while (i<=255) and (drivestr[i]<>0) do
      begin
      s:=s+char(drivestr[i]);
      inc(i);
      end;
   inc(i);
   if length(s)>0 then
      begin
      c:=upcase(s[1]);
      j:=ord(c)-64;
      if j<3 then
         begin
         //check if A: and B: are floppy disks
         ErrorMode := SetErrorMode(SEM_FailCriticalErrors);
         try
         sz:=disksize(j);
         if sz<3000000 then
            begin
            s1:=s;
            setlength(s1,length(s1)-1);
            devname[k]:='('+s1+') '+txt_unit_floppy;
            devtype[k]:=1;
            devicon[j]:=setpcmenuicon(devtype[k]);
            continue;
            end;
         finally
            SetErrorMode(ErrorMode);
         end;
         end;
      //drive type
      t:=getdrivetype(Pchar(s));
      case t of
         2: dtype:=txt_unit_removable;
         3: dtype:=txt_unit_hd;
         4: dtype:=txt_unit_remote;
         5: dtype:=txt_unit_cd;
         6: dtype:=txt_unit_ram;
         else dtype:=txt_unit_unknown;
         end;
      devtype[k]:=t;
      devicon[j]:=setpcmenuicon(devtype[k]);
      //drive name
      w:=utf8decode(s);
      tsout:=datetimetotimestamp(now);
      tdiff:=tsout.time-tsin.time;
      if testdriveaccessible(s,dtype,tdiff)=true then
         GetVolumeInformationW(Pwidechar(w),
         @bufVolumeName, sizeof(bufVolumeName),
         @sn, mc, flags,
         @bufFSName, sizeof(bufFSName));
      if bufVolumeName<>'' then begin ws:=bufVolumeName; dname:=AnsiString(ws); end
      else dname:=dtype;
      //unc name
      if dtype=txt_unit_remote then uncname:=getUNCname(Pchar(s))
      else uncname:='';
      if uncname<>'' then
         if uncname[length(uncname)]=directoryseparator then setlength(uncname,length(uncname)-1);
      s1:=s;
      setlength(s1,length(s1)-1);
      if uncname='' then devname[k]:='('+s1+') '+dname
      else devname[k]:='('+s1+') '+uncname+' '+txt_on+' '+dname;
      end;
until length(s)=0;
if devname[1]<>'' then
   begin
   FormPeach.pmjd1.Visible:=true;
   FormPeach.pmjd1.Caption:=devname[1];
   FormPeach.pmjd1.bitmap:=setpcmenuicon(devtype[1]);
   copyunitmenu(FormPeach.pmjd1,FormPeach.pojdn1);
