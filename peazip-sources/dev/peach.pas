function set_grid:boolean;
var
   rc,i:integer;
begin
try
set_grid:=false;
rc:=FormPeach.Stringgridlist.Rowcount;
if rc<2 then exit;
if FormPeach.StringgridList.Cells[1,1]='' then exit;
if FormPeach.ListViewBrowser.Items.Count<1 then exit;
{$IFDEF MSWINDOWS}//works properly on Lazarus 0.9.30
if FormPeach.ListViewBrowser.Selected<>nil then i:=FormPeach.ListViewBrowser.Selected.Index
else exit;
if FormPeach.ListViewBrowser.Items[i].selected=true then FormPeach.StringGridList.Row:=i+1;
set_grid:=true;
{$ELSE}
if rc>1 then
   for i:=1 to rc-1 do
      try
      if FormPeach.ListViewBrowser.Items[i-1].selected=true then
         begin
         FormPeach.Stringgridlist.Row:=i;
         set_grid:=true;
         break;
         end;
      except
      end;
{$ENDIF}
except
end;
end;

