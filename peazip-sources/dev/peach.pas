   FormPeach.SaveDialogAS.FileName:=addext(s);
   if lastoutpath='' then lastoutpath:=local_desktop; //if no path was previously used, or after configuration reset, show desktop as default
   FormPeach.SaveDialogAS.InitialDir:=extractfilepath(FormPeach.EditAddName.Caption);//Initialdir:=lastoutpath;
   if FormPeach.SaveDialogAS.Execute then
      if FormPeach.SaveDialogAS.FileName<>'' then
         begin
         s:=FormPeach.SaveDialogAS.FileName;
         cutextension(s);
         s1:=extractfilepath(FormPeach.SaveDialogAS.FileName);
         if s=addext(s1) then s:=extractfilepath(FormPeach.SaveDialogAS.FileName);
         end
      else exit
   else exit;
   lastoutpath:=extractfilepath(FormPeach.SaveDialogAS.FileName);
getoutname:=0;
end;

