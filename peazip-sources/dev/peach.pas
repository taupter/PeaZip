procedure viewimageloop;
var
   i:integer;
   ifound,iupdated:boolean;
begin
iupdated:=false;
repeat
viewimage;
if FormImgViewer.ModalResult=mrRetry then //reload image viewer passing updated list of items starting from first valid image, exit if no image is found
   begin
   FormImgViewer.StringGridImgViewer.RowCount:=1;
   ifound:=false;
   iupdated:=true;
   FormPeach.mRefreshClick(nil);
   if FormPeach.StringGridList.RowCount<2 then exit;
   if FormPeach.StringGridList.Cells[1,1]='' then exit;
   if fun<>'FILEBROWSER' then exit; //safety double check: update is not needed/enabled inside archives
   for i:=1 to FormPeach.StringGridList.RowCount-1 do //search match with last item viewed
      if supportedimgtype(FormPeach.StringGridList.Cells[2,i])=true then
         begin
         if not FileExists(FormPeach.StringGridList.Cells[12,i]) then Continue;
         if FormPeach.StringGridList.Cells[12,i]=imageviewername then
            begin
            FormPeach.StringGridList.Cells[16,i]:='1';
            ifound:=true;
            break;
            end;
         end;
   if ifound=false then //if no match found with last viewed item, search match with first valid image
    for i:=1 to FormPeach.StringGridList.RowCount-1 do
      if supportedimgtype(FormPeach.StringGridList.Cells[2,i])=true then
         begin
         if not FileExists(FormPeach.StringGridList.Cells[12,i]) then Continue;
         FormPeach.StringGridList.Cells[16,i]:='1';
         ifound:=true;
         break;
         end;
   if ifound=false then exit;
   end;
until FormImgViewer.ModalResult<>mrRetry;
if iupdated=true then FormPeach.mRefreshClick(nil);
end;

