function compose_upx_cl(var cl,jobcode,outname,sel:ansistring):integer;
var
   P:tprocessutf8;
   numread,numwritten:integer;
   fin,fout:file of byte;
   read_data:array[0..65535]of byte;
   in_param,bin_name,compression_level,s,sl,clstrip:ansistring;
begin
compose_upx_cl:=-1;
fun:='UPX';
subfun:='archive';
btfun:='upx';
updatecontent(FormPeach.StringGridAdd,tvolumes,tdirs,tfiles,tsize,false);
setspecialtsize;//should not apply
//check if input is suitable for chosen archive_type
if check_input<>0 then exit;
sl:=upcase(FormPeach.StringGridAdd.Cells[2,1]);
if (tdirs=0) and (FormPeach.StringGridAdd.RowCount<3) and
   ((sl='.EXE') or
   (sl='.COM') or
   (sl='.DLL') or
   (sl='.OCX') or
   (sl='.SCR') or
   (sl='.SFX') or
   (sl='.SYS') or
   (sl='.ELF') or
   (sl='.O') or
   (sl='.SO') or
   (sl='.DYLIB') or
   (sl='')) then //single input executable file
else //folder(s) and/or multiple files
   begin
   pMessageWarningOK(archive_type+' '+txt_error_input_upx);
   exit;
   end;
if (FormPeach.ComboBoxUPX.ItemIndex=0) and (FormPeach.CheckBoxUPXStrip.State=cbUnchecked) then
   begin
   pMessageWarningOK(txt_upxorstrip);
   exit;
   end;
if FormPeach.ComboBoxUPX.ItemIndex=10 then compression_level:='--best'
else compression_level:='-'+inttostr((FormPeach.ComboBoxUPX.ItemIndex));
get_in_param(in_param,sel);
outname:=FormPeach.StringGridAdd.Cells[8,1];
{$IFDEF MSWINDOWS}
if not(FileExists(binpath+'upx'+DirectorySeparator+'upx.exe')) then
   begin
   cl:='';
   exit;
   end;
{$ENDIF}
bin_name:=stringdelim(escapefilename(binpath,desk_env)+'upx'+DirectorySeparator+'upx'+EXEEXT);
if sys7zlin>1 then bin_name:='upx'+EXEEXT;
cl:=bin_name+' '+compression_level;
cl:=cl+' '+in_param;
jobcode:=formatdatetime('yyyymmdd_hh.nn.ss.ms_',now)+fun;
//do backup (silent) before strip/upx
if FormPeach.CheckBoxUPXBackup.State=cbChecked then
   begin
   assignfile(fin,FormPeach.StringGridAdd.Cells[8,1]);
   filemode:=0;
   reset(fin);
   assignfile(fout,FormPeach.StringGridAdd.Cells[8,1]+'.backup');
   rewrite(fout);
   repeat
      blockread (fin,read_data,65536,numread);
      blockwrite (fout,read_data,numread,numwritten);
   until ((numread=0) or (numread<>numwritten));
   closefile(fin);
   closefile(fout);
   end;
//strip (silent) before upx
if FormPeach.CheckBoxUPXStrip.State=cbChecked then
   begin
   P:=tprocessutf8.Create(nil);
   {$IFDEF MSWINDOWS}
   clstrip:=('"'+binpath+'upx'+DirectorySeparator+'strip.exe" '+in_param);
   {$ELSE}//assuming generic unix coming with strip command
   clstrip:=('strip '+in_param);
   {$ENDIF}
   if FormPeach.Visible=true then Application.ProcessMessages;
   P.Options := [poWaitOnExit{$IFDEF MSWINDOWS}, poNoConsole{$ENDIF}];
   if validatecl(clstrip)<>0 then begin pMessageWarningOK(txt_2_7_validatecl+' '+clstrip); exit; end;
   {$IFDEF MSWINDOWS}
   if FileExists(binpath+'upx'+DirectorySeparator+'strip.exe') then
   {$ENDIF}
   peapexecute(P,clstrip);
   P.Free;
   end;
if FormPeach.ComboBoxUPX.ItemIndex=0 then //exit with -1 exitcode, not launching the task
   begin
   cl:='';
   exit;
   end;
compose_upx_cl:=0;
end;

