      FormPeach.pmhtabs.Checked:=false;
      FormPeach.pmtabsm.Checked:=false;
      FormPeach.pmtab.Checked:=false;
      FormPeach.mtab.Checked:=false;
      end;
   1: begin
      FormPeach.PanelTabBar.height:=tabheight-4;
      FormPeach.PanelTabBar.visible:=true;
