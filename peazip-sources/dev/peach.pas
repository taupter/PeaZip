   FormPeach.CheckBoxzpaqforce.visible:=false;
   end;
   1: //zpaq extended options (all etended options)
   begin
   FormPeach.PanelExtZPAQ.visible:=true;
   FormPeach.Labeladvextzpaq.visible:=true;
   FormPeach.ComboBoxActionExtract.enabled:=false;
   FormPeach.ComboBoxOverwrite.enabled:=false;
   FormPeach.LabelAdvExtZpaqBrZst.visible:=true;
   FormPeach.CheckBoxzpaqforce.visible:=true;
   end;
   2: //all options
   begin
   FormPeach.PanelExtZPAQ.visible:=true;
   FormPeach.Labeladvextzpaq.visible:=true;
   FormPeach.ComboBoxActionExtract.enabled:=true;
   FormPeach.ComboBoxOverwrite.enabled:=true;
