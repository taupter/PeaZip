procedure update_listview;
var
   i,j,rc:integer;
   MyThreadimg: TMyThreadimg;
   abitmap:TBitmap;
   redoi:boolean;
   tstr:ansistring;
   tvs:TViewStyle;
begin
if updatinglistview=true then exit;
updatinglistview:=true;
if dolistupdate=false then
   begin
   updatinglistview:=false;
   exit;
   end;
savecol;
if (fun<>'FILEBROWSER') and (funflag=true) then browser_selectnone; //start with no selection opening archive, so "extract" selects all by default
if (fun='FILEBROWSER') and (FormPeach.StringGridSessionHistory.RowCount<=2) then browser_selectnone; //start with no selection opening the application, so "add" and "extract" goes to new empty layout by default
