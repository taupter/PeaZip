   FormImgCrop.AlphaBlend:=true;
   FormImgCrop.AlphaBlendValue:=FormPeach.AlphaBlendValue;
   FormImgRes.AlphaBlend:=true;
   FormImgRes.AlphaBlendValue:=FormPeach.AlphaBlendValue;
   FormImgViewer.AlphaBlend:=true;
   FormImgViewer.AlphaBlendValue:=FormPeach.AlphaBlendValue;
   FormInput.AlphaBlend:=true;
   FormInput.AlphaBlendValue:=FormPeach.AlphaBlendValue;
   FormKF.AlphaBlend:=true;
   FormKF.AlphaBlendValue:=FormPeach.AlphaBlendValue;
   FormPaths.AlphaBlend:=true;
   FormPaths.AlphaBlendValue:=FormPeach.AlphaBlendValue;
   FormPM.AlphaBlend:=true;
   FormPM.AlphaBlendValue:=FormPeach.AlphaBlendValue;
   FormPW.AlphaBlend:=true;
   FormPW.AlphaBlendValue:=FormPeach.AlphaBlendValue;
   FormSelect.AlphaBlend:=true;
   FormSelect.AlphaBlendValue:=FormPeach.AlphaBlendValue;
   Formweb.AlphaBlend:=true;
