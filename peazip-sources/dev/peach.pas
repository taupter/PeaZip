procedure TFormPeach.SchedAddscheduleExtChange(Sender: TObject);
begin
DateEditExt1.Date:=Now;
PanelHDWExt.visible:=false;
PanelWeeklyExt.visible:=false;
PanelMonthlyExt.visible:=false;
lse3.Visible:=true;
schedulehhext.Visible:=true;
schedulemmext.Visible:=true;
scheduleNNext.value:=1;
BScheduleExt.Enabled:=true;
case SchedAddscheduleExt.itemindex of
   0: //hourly
   begin
   PanelHDWExt.visible:=true;
   LabelEveryUnitExt.Caption:=txt_5_1_hours;
   scheduleNNext.maxvalue:=24;
   end;
