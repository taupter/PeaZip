   i,k:integer;
   clprog:ansistring;
begin
importjobcl_extract:=0;
with FormPeach do
begin
mConsoleCreateExt.Clear;
lConsoleCreate_jobcodeExt.Caption:='';
lConsoleCreate_outnameExt.Caption:='';
if FormPeach.LabelStatusExtract.Caption=txt_2_7_ext then
   begin
   clprog:='';
   k:=FormPeach.StringGridExtract.RowCount;
   FormPeach.StringGridExtract.Row:=1;
