   if FormPeach.ListViewBrowser.Items[i-1].Selected=true then
      begin
      nsel:=nsel+1;
      case nsel of
         1: strsel:=strsel+FormPeach.ListViewBrowser.Items[i-1].Caption+char($0D)+char($0A);
         2: strsel:=strsel+FormPeach.ListViewBrowser.Items[i-1].Caption+char($0D)+char($0A);
