   {$IFDEF MSWINDOWS}
   if FormPeach.Visible=true then
      try
      FormPeach.ListViewBrowser.ItemFocused:=FormPeach.ListViewBrowser.Items[FormPeach.StringGridList.Row-1];
      except
      end;
   {$ENDIF}
