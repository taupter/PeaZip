   //2: FormPeach.Caption:=FormPeach.Caption;
   3: FormPeach.Caption:=FormPeach.Caption+' | '+txt_7_4_locked;
   end;
case i of
   -1: //not rar
      begin
      end;
   else //rar
      if (havewinrar=true) and (userar=1) then
      begin
      FormPeach.pmmorerr.Visible:=true;
      FormPeach.pmmorerecover.Visible:=true;
      FormPeach.po_rr.Visible:=true;
      FormPeach.po_recover.Visible:=true;
      end;
   end;
end;

