begin
wasselectedp:=wasselected;
wasselected:=-1;
pclicked:=true;
if (fun<>'FILEBROWSER') and (fun<>'UN7Z') then exit;
{$IFDEF MSWINDOWS}if FormPeach.EditOpenIn.Text=txt_mypc then exit;{$ENDIF}
if updatinglistview=true then exit;
if FormPeach.StringGridList.Rowcount<2 then exit;
if FormPeach.StringGridList.Cells[1,1]='' then exit;
if FormPeach.ListViewBrowser.SelCount<>1 then exit;
if FormPeach.StringGridList.Cells[16,FormPeach.StringGridList.Row]<>'1' then exit;
try
   wasselected:=FormPeach.ListViewBrowser.ItemFocused.Index+1;
except
end;
if wasselectedp=wasselected then
   if FormPeach.ListViewBrowser.SelCount=1 then
      begin
      {
      //possible implementation for rename in place editing the listview
      {$IFDEF MSWINDOWS}
      enter_busy_status_special;//may be used a custom busy status to not trigger the refresh progress bar
      FormPeach.ListViewBrowser.ReadOnly:=false;
      FormPeach.ListViewBrowser.ItemFocused.EditCaption;
      renorig:=FormPeach.EditOpenIn.Text;
      {$ELSE}
      Timerrename.Enabled:=true;
      {$ENDIF}
      }
      if ListViewBrowser.OwnerData=false then Timerrename.Enabled:=true;
      end;
end;

