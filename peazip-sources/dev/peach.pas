            exetodo[exeindex]:=exeindex;
            if browsertype= 2 then il96.Add(abitmap,nil)
            else
               if smalliconsize=16 then il16.Add(abitmap,nil)
               else il96.Add(abitmap,nil);
            end;
         end;
         end;
      end;
   FormPeach.ListViewBrowser.Visible:=true;
   if showthumbnails=1 then
      if fun='FILEBROWSER' then
         begin
         MyThreadimg := TMyThreadimg.Create(True);
         if Assigned(MyThreadimg.FatalException) then
            raise MyThreadimg.FatalException;
         MyThreadimg.Resume;
         end;
   {$ENDIF}
   abitmap.free;
   end
   else //virtual
      begin
      if FormPeach.ListViewBrowser.OwnerData=false then FormPeach.ListViewBrowser.OwnerData:=true;
      FormPeach.ListViewBrowser.Items.Count:=rc-1;
      end;
   end
else
   begin
   set_listview_col;
   FormPeach.ListViewBrowser.Items.Endupdate;
   update_addressbar(FormPeach.EditOpenInInteractive.Text);
   update_selstatus;
   updatinglistview:=false;
   exit;
   end;

