if FormPeach.PanelProgress.Visible=true then
   begin
   FormPeach.PanelProgress.Width:=FormPeach.Width*95 div 100;
   pperc:=95;
   tstr:=FormPeach.LabelStatusdisplayed.Caption;
   FormPeach.LabelStatusdisplayed.Caption:=txt_8_9_disp+' 2/2';
   application.ProcessMessages;
   FormPeach.LabelStatusdisplayed.Caption:=tstr;
   end;

//sync real time search
FormPeach.ListAddress.Items.BeginUpdate;
FormPeach.ListAddress.Clear;
if FormPeach.ListViewBrowser.OwnerData=false then //current filter implementation not compatible with virtual treeview
   for j:=0 to FormPeach.ListViewBrowser.Items.Count-1 do FormPeach.ListAddress.Items.Add.Assign(FormPeach.ListViewBrowser.Items[j]);
FormPeach.ListAddress.Items.EndUpdate;
FormPeach.StringGridAddress.BeginUpdate;
