procedure TFormPeach.CheckBoxTarBeforeClick(Sender: TObject);
var
   s:ansistring;
begin
if CheckBoxTarBefore.State=cbChecked then
   begin
   if CheckBoxSeparate.State=cbChecked then
      begin
      EditAddFilename.Enabled:=true;
      suggest_outname(s,FormPeach.cbType.Text,FormPeach.StringGridAdd.Row);
      EditAddFilename.Text:=extractfilename(s);
      EditAddName.Text:=FormPeach.EditAddFilepath.Text+addext(FormPeach.EditAddFilename.Text);
      end;
   CheckBoxSeparate.State:=cbUnChecked;
   CheckBoxSeparate.Enabled:=false;
   CheckBoxSameArc.State:=cbUnChecked;
   CheckBoxSameArc.Enabled:=false;
   CheckBoxConvert.State:=cbUnChecked;
   CheckBoxConvert.Enabled:=false;
   CheckBoxConvertPW.visible:=CheckBoxConvert.Checked;
   CheckBoxConvertVerbose.visible:=CheckBoxConvert.Checked;
   end
else
   begin
   CheckBoxSameArc.Enabled:=true;
   CheckBoxSeparate.Enabled:=true;
   CheckBoxConvert.Enabled:=true;
   end;
end;

