FormPeach.ImageListResetSearch.visible:=false;
FormPeach.ListViewBrowser.Items.Beginupdate;
update_info;
//application.processmessages; Win32 Lazarus 0.9.30, browsing computer's root may crash (at application.processmessages in update_listview) at application startup if sorting column is not unit name
FormPeach.ListViewBrowser.Clear;
{$IFDEF MSWINDOWS}
if prevupdateid<>updateid then redoi:=true else redoi:=false;
if showthumbnails=0 then redoi:=false;
if openstarted=false then redoi:=true;
rebuildicons(redoi);
{$ELSE}
rebuildicons(false);
{$ENDIF}

if rc>1 then
   begin

   {$IFDEF DARWIN}//never return to non-virtual mode at runtime in macOS due to listview selectitem event non being triggered in this case (limitation tested in laz 4.2)
   if FormPeach.ListViewBrowser.OwnerData=true then
      begin
      sizevirtual:=0;
      allowvirtual:=1;
      end;
   {$ENDIF}

   if (rc<sizevirtual*1024) or (allowvirtual=0) then //non-virtual mode; possible variation, add condition to force for win thumbnails ((fun='FILEBROWSER') and (showthumbnails=1))
   begin
   if FormPeach.ListViewBrowser.OwnerData=true then
      begin
      FormPeach.ListViewBrowser.OwnerData:=false;
      {$IFDEF LCLGTK2}//forces GTK2 to redraw the GUI, otherwise listview items will remain invisible
      FormPeach.BorderStyle:=bsNone;
      FormPeach.BorderStyle:=bsSizeable;
      {$ENDIF}
      end;

   abitmap:=Tbitmap.Create;
   if browsertype=2 then
      begin
      abitmap.Width:=largeiconsize;
      abitmap.Height:=largeiconsize;
      end
   else
      begin
      abitmap.Width:=smalliconsize;
      abitmap.Height:=smalliconsize;
      end;
   {$IFDEF MSWINDOWS}
   FormPeach.ListViewBrowser.Visible:=false;
   tvs:=FormPeach.ListViewBrowser.ViewStyle;
   if tvs=vsReport then FormPeach.ListViewBrowser.ViewStyle:=vsSmallIcon;
   //changing viewstyle on the fly produces issues with some non-Windows widgetsets, moreover the advantage is mainly noticeable only on Windows
   {$ENDIF}
   for i:=1 to rc-1 do
      begin
      FormPeach.ListViewBrowser.Items.Add.Caption:=FormPeach.StringGridList.Cells[1,i];
      {$IFNDEF MSWINDOWS}FormPeach.ListViewBrowser.Items[i-1].ImageIndex:=drawlisticon(i);{$ENDIF}
      FormPeach.ListViewBrowser.Items[i-1].SubItems.Add(FormPeach.StringGridList.Cells[2,i]);
      FormPeach.ListViewBrowser.Items[i-1].SubItems.Add(nicenumber(FormPeach.StringGridList.Cells[3,i],filesizebase));
      FormPeach.ListViewBrowser.Items[i-1].SubItems.Add(nicenumber(FormPeach.StringGridList.Cells[4,i],filesizebase));
      FormPeach.ListViewBrowser.Items[i-1].SubItems.Add(FormPeach.StringGridList.Cells[5,i]);
      FormPeach.ListViewBrowser.Items[i-1].SubItems.Add(FormPeach.StringGridList.Cells[6,i]);
      FormPeach.ListViewBrowser.Items[i-1].SubItems.Add(FormPeach.StringGridList.Cells[7,i]);
      FormPeach.ListViewBrowser.Items[i-1].SubItems.Add(FormPeach.StringGridList.Cells[8,i]);
      FormPeach.ListViewBrowser.Items[i-1].SubItems.Add(FormPeach.StringGridList.Cells[9,i]);
      FormPeach.ListViewBrowser.Items[i-1].SubItems.Add(FormPeach.StringGridList.Cells[10,i]);
      FormPeach.ListViewBrowser.Items[i-1].SubItems.Add(FormPeach.StringGridList.Cells[11,i]);
      FormPeach.ListViewBrowser.Items[i-1].SubItems.Add(FormPeach.StringGridList.Cells[12,i]);
      if FormPeach.StringGridList.Cells[16,i]='0' then
      else
         try
         FormPeach.ListViewBrowser.Items[i-1].Selected:=true;
         except
         end;
      end;
   {$IFDEF MSWINDOWS}
   if tvs=vsReport then FormPeach.ListViewBrowser.ViewStyle:=tvs;
   for i:=1 to rc-1 do
      begin
      FormPeach.ListViewBrowser.Items[i-1].ImageIndex:=drawlisticon(i);
      if fun='FILEBROWSER' then
         begin
         if showthumbnails=1 then
            begin
            if supportedimgtype(FormPeach.StringGridList.Cells[2,i])=true then
            begin
            imindex:=imindex+1;
            SetLength(imlistindex, imindex+1);
