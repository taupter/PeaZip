procedure setwindowsopacity;
begin
if (opacity<100) or (spinchanged=true) then
   begin
   if opacity<100 then FormPeach.AlphaBlend:=true else FormPeach.AlphaBlend:=false;
   FormPeach.AlphaBlendValue:=255+opacity-100;
   end;
spinchanged:=false;
FormPeach.SpinEditOpacity.Value:=opacity;
if opacity<100 then
   begin
   FormGwrap.AlphaBlend:=true;
   FormGwrap.AlphaBlendValue:=FormPeach.AlphaBlendValue;
   FormAdvf.AlphaBlend:=true;
   FormAdvf.AlphaBlendValue:=FormPeach.AlphaBlendValue;
   FormComment.AlphaBlend:=true;
   FormComment.AlphaBlendValue:=FormPeach.AlphaBlendValue;
   FormDlg.AlphaBlend:=true;
   FormDlg.AlphaBlendValue:=FormPeach.AlphaBlendValue;
