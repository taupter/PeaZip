procedure getarccaption(s:ansistring);
begin
UnitGwrap.parcstr:='';
case s of
STR_7Z,STR_ZIP:
   begin
   FormPeach.Caption:=FormPeach.ComboBox7zFun.Text+' .'+archive_type+', '+compression_level+', '+compression_method;
   if (FormPW.EditPWpass.Caption<>'') or (FormPW.EditPWkeyfile.Caption<>'') then FormPeach.Caption:=FormPeach.Caption+' | '+FormPeach.ComboBox7zalgo.Text;
   UnitGwrap.parcstr:=', '+compression_level+', '+compression_method;
   if (FormPW.EditPWpass.Caption<>'') or (FormPW.EditPWkeyfile.Caption<>'') then UnitGwrap.parcstr:=UnitGwrap.parcstr+' | '+FormPeach.ComboBox7zalgo.Text;
   end;
STR_BZIP2, STR_GZIP, STR_WIM, STR_XZ, STR_TAR:
   begin
   FormPeach.Caption:=FormPeach.ComboBox7zFun.Text+' .'+archive_type+', '+compression_level;
   UnitGwrap.parcstr:=', '+compression_level;
   end;
STR_ARC:
   begin
   FormPeach.Caption:=txt_create+' .'+archive_type+', '+FormPeach.ComboBoxARCFun.Text;
   if (FormPW.EditPWpass.Caption<>'') or (FormPW.EditPWkeyfile.Caption<>'') then FormPeach.Caption:=FormPeach.Caption+' | '+FormPeach.ComboBoxARCalgo.Text;
   end;
STR_PEA:
   begin
   FormPeach.Caption:=txt_create+' .pea';
   if (FormPW.EditPWpass.Caption<>'') or (FormPW.EditPWkeyfile.Caption<>'') then FormPeach.Caption:=FormPeach.Caption+' | '+FormPeach.ComboBoxPEAStream.Text;
   end;
STR_ZPAQ, STR_QUAD:
   begin
   FormPeach.Caption:=txt_create+' .'+archive_type;
   end;
STR_BROTLI, STR_ZSTD:
   begin
   FormPeach.Caption:=txt_create+' .'+archive_type+', '+txt_level+' '+FormPeach.cbLevel.Caption;
   UnitGwrap.parcstr:=', '+txt_level+' '+FormPeach.cbLevel.Caption;
   end;
STR_UPX: FormPeach.Caption:=txt_compress_executable;
else
begin
if (s=txt_custom) or (s=txt_custom+'/RAR') then
   if (userar=1) and (havewinrar=true) then
      begin
      FormPeach.Caption:=FormPeach.ComboBox7zFun.Text+' .rar, '+FormPeach.cbLevel.Caption;
      if (FormPW.EditPWpass.Caption<>'') or (FormPW.EditPWkeyfile.Caption<>'') then FormPeach.Caption:=FormPeach.Caption+' | '+txt_encrypt;
      UnitGwrap.parcstr:=', '+FormPeach.cbLevel.Caption;
      if (FormPW.EditPWpass.Caption<>'') or (FormPW.EditPWkeyfile.Caption<>'') then UnitGwrap.parcstr:=UnitGwrap.parcstr+' | '+txt_encrypt;
      end
   else
      begin
      FormPeach.Caption:=txt_custom;
      end;
if s=txt_split then FormPeach.Caption:=txt_split;
if s=txt_sfx+' '+STR_7Z then
   begin
   FormPeach.Caption:=FormPeach.ComboBox7zFun.Text+' '+txt_sfx+' ('+STR_7Z+'), '+compression_level+', '+compression_method;
   if (FormPW.EditPWpass.Caption<>'') then FormPeach.Caption:=FormPeach.Caption+' | '+FormPeach.ComboBox7zalgo.Text;
   UnitGwrap.parcstr:=', '+compression_level+', '+compression_method;
   if (FormPW.EditPWpass.Caption<>'') then UnitGwrap.parcstr:=UnitGwrap.parcstr+' | '+FormPeach.ComboBox7zalgo.Text;
   end;
if s=txt_sfx+' '+STR_ARC then
   begin
   FormPeach.Caption:=txt_create+' '+txt_sfx+' ('+STR_ARC+'), '+FormPeach.ComboBoxARCFun.Text;
   if (FormPW.EditPWpass.Caption<>'') then FormPeach.Caption:=FormPeach.Caption+' | '+FormPeach.ComboBoxARCalgo.Text;
   end;
end;
end;
end;

