         else FormPeach.Caption:=txt_7_0_af+', ('+inttostr(i)+'/'+inttostr(rc)+') '+FormPeach.StringGridList.Cells[1,i]+'...';
         nfiles:=0;
         ndirs:=0;
         ctsize:=0;
         rcountsize(FormPeach.StringGridList.Cells[12,i]+directoryseparator,'*',faAnyFile,true,nfiles,ndirs,ctsize);
         FormPeach.StringGridList.Cells[3,i]:=nicenumber(inttostr(ctsize),filesizebase);
         FormPeach.StringGridList.Cells[14,i]:=inttostr(length(inttostr(length(inttostr(ctsize)))))+inttostr(length(inttostr(ctsize)))+inttostr(ctsize);
         FormPeach.ListViewBrowser.Items[i-1].SubItems[1]:=FormPeach.StringGridList.Cells[3,i];
