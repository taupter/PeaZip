assignfile(t,s);
rewrite(t);
write_header(t);
for x:=1 to FormPeach.StringGridList.RowCount-1 do
   begin
   for y:=1 to 8 do
      write(t,FormPeach.StringGridList.Cells[y,x]+field_delim);
   writeln(t);
   end;
closefile(t);
end;
end;

