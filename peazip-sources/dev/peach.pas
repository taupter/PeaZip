//for j:=0 to FormPeach.StringGridList.RowCount-1 do FormPeach.StringGridAddress.Rows[j].Assign(FormPeach.StringGridList.Rows[j]);
FormPeach.StringGridAddress.Assign(FormPeach.StringGridList);
FormPeach.StringGridAddress.EndUpdate;

