procedure TFormPeach.ListViewBrowserData(Sender: TObject; Item: TListItem);
//current limitations of listview in virtual mode:
//disable showing exe icons and images thubnails (Windows, browsing the filesystem) for performances reasons needs to run in separate threads which are implemented in non virtual mode.
//disable dynamic content filter typing in the address bar (the mirror listview item is not created when virtual mode is set).
//SelectItem needs to parse the entire listview, fast selection routine for Windows was disabled (other OSes does not support this routine and are faster at updating the selection using the slow routine).
//This leads to disable item rename with mouse click, rename is only reached from F2 or from menu (as the slow selection may be misleading for users at least on Windows)
//With virtual mode it is not easy to set focus to the last browsed item, even if selection is correct
{$IFDEF MSWINDOWS}
var
   abitmap,bbitmap:TBitmap;
   icon1:TIcon;
   eisize,p,x,y,k:integer;
   s,fs:ansistring;
   fileinfo: SHFILEINFO;
{$ENDIF}
begin
if Item.Index>=FormPeach.StringGridList.RowCount-1 then exit;
if updatingsel=true then exit;
updatingsel:=true;
//updatinglistview:=true;
Item.Caption:=FormPeach.StringGridList.Cells[1,Item.Index+1];
Item.SubItems.Add(FormPeach.StringGridList.Cells[2,Item.Index+1]);
Item.SubItems.Add(nicenumber(FormPeach.StringGridList.Cells[3,Item.Index+1],filesizebase));
Item.SubItems.Add(nicenumber(FormPeach.StringGridList.Cells[4,Item.Index+1],filesizebase));
Item.SubItems.Add(FormPeach.StringGridList.Cells[5,Item.Index+1]);
Item.SubItems.Add(FormPeach.StringGridList.Cells[6,Item.Index+1]);
Item.SubItems.Add(FormPeach.StringGridList.Cells[7,Item.Index+1]);
Item.SubItems.Add(FormPeach.StringGridList.Cells[8,Item.Index+1]);
Item.SubItems.Add(FormPeach.StringGridList.Cells[9,Item.Index+1]);
Item.SubItems.Add(FormPeach.StringGridList.Cells[10,Item.Index+1]);
Item.SubItems.Add(FormPeach.StringGridList.Cells[11,Item.Index+1]);
Item.SubItems.Add(FormPeach.StringGridList.Cells[12,Item.Index+1]);
if FormPeach.StringGridList.Cells[16,Item.Index+1]='1' then
   try
   Item.Selected:=true;
   except
   end;
Item.ImageIndex:=drawlisticon(Item.Index+1);
{
//loading exe icons and images thumbnails needs to be performed in separate threads for performances
//in this case treeview is set in non-virtual mode at runtime
{$IFDEF MSWINDOWS}
if fun='FILEBROWSER' then
   begin
   //load exe icons
   if FormPeach.StringGridList.Cells[2,Item.Index+1]='.exe' then
      if strtoint(FormPeach.StringGridList.Cells[3,Item.Index+1])<64000000 then //don't search for icons if exe is large, for performance reasons
      begin
      case browsertype of
         2: eisize:=largeiconsize;
         1: eisize:=smalliconsize;
         0: eisize:=smalliconsize;
      end;
      if eisize>0 then
         begin
         try
            abitmap:=Tbitmap.Create;
            bbitmap:=Tbitmap.Create;
            icon1:=TIcon.Create;
            s:=FormPeach.StringGridList.Cells[12,Item.Index+1];
            k:=0;
            if eisize=16 then k:=SHGetFileInfo(pchar(s), 0, fileinfo, sizeof(fileinfo), SHGFI_ICON or SHGFI_SMALLICON)
            else k:=SHGetFileInfo(pchar(s), 0, fileinfo, sizeof(fileinfo), SHGFI_ICON or SHGFI_LARGEICON);
            if k<>0 then
               begin
               icon1.Handle:=fileinfo.hIcon;
               abitmap.Height:=icon1.Height;
               abitmap.Width:=icon1.Width;
               abitmap.Canvas.draw(0,0,icon1);
               p:=0;
               for y:=0 to icon1.Height-1 do
                  for x:=0 to icon1.Width-1 do
                     if (icon1.Canvas.Pixels[x,y]<>$FFFFFF) and (icon1.Canvas.Pixels[x,y]<>$000000) then
                        begin
                        p:=p+1;
                        Break;
                        end;
               if p<>0 then
                  begin
                  abitmap.TransparentColor:=clBlack;
                  abitmap.Transparent:=true;
                  end;
               DestroyIcon(fileinfo.hIcon);
               end
            else
               begin
               abitmap:=Tbitmap.Create;
               abitmap.Assign(FormPeach.ListViewBrowser.Items[1]);
               end;
            if eisize=16 then
               begin
               setpbitmap(abitmap, (icon1.Width*pzoom) div 100);
               setsize_bitmap(abitmap, icon_sizeplus, DECO_NONE);
               il16.Add(abitmap,nil);
               Item.ImageIndex:=il16.Count-1;
               end
            else
               begin
               setpbitmap(abitmap,scalediconsize);
               loadlargeicon(abitmap,bbitmap,spacedscalediconsize);
               il96.Add(bbitmap,nil);
               Item.ImageIndex:=il96.Count-1;
               end;
         finally
            abitmap.free;
            bbitmap.free;
            icon1.Free;
         end;
         end;
      end;
   //load thumbnails of images
   if showthumbnails=1 then
   if supportedimgtype(FormPeach.StringGridList.Cells[2,Item.Index+1])=true then
      begin
      abitmap:=Tbitmap.Create;
      load_bitmap(abitmap, FormPeach.StringGridList.Cells[12,Item.Index+1], scalediconsize, deco_style, fs);
      setsize_bitmap(abitmap, spacedscalediconsize, DECO_NONE);
      case browsertype of
         2: eisize:=largeiconsize;
         1: eisize:=smalliconsize;
         0: eisize:=smalliconsize;
      end;
      if eisize=16 then
         begin
         il16.Add(abitmap,nil);
         Item.ImageIndex:=il16.Count-1;
         end
      else
         begin
         il96.Add(abitmap,nil);
         Item.ImageIndex:=il96.Count-1;
         end;
      FormPeach.StringGridList.Cells[4,Item.Index+1]:=fs;
      FormPeach.StringGridList.Cells[15,Item.Index+1]:=fs;
      abitmap.free;
      end;
   end;
{$ENDIF}
}
//updatinglistview:=false;
updatingsel:=false;
end;

