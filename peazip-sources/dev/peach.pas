function padstrsort(c,i:integer):ansistring;
begin case c of
   2,15,10: result:=PadRight(FormPeach.StringGridList.Cells[c,i],16)+FormPeach.StringGridList.Cells[13,i]; //ext, info, attr
   9,11: result:=PadRight(FormPeach.StringGridList.Cells[c,i],32)+FormPeach.StringGridList.Cells[13,i]; //comment, crc
   else
      result:=FormPeach.StringGridList.Cells[c,i];
   end;
end;

procedure sort_az_stringgridlist(c:integer);
var
  i,rc:integer;
begin
if refreshstatus<>0 then exit;
rc:=FormPeach.StringGridList.Rowcount;
if rc>1 then
   for i:=1 to rc-1 do
      begin
      if FormPeach.StringGridList.Cells[2,i]<>txt_list_isfolder then
         FormPeach.StringGridList.Cells[17,i]:=prefixfaz+padstrsort(c,i)
      else
         FormPeach.StringGridList.Cells[17,i]:=prefixdaz+padstrsort(c,i);
      end;
FormPeach.StringGridList.SortColRow(true,17);
end;

procedure sort_az_stringgridlist_special(c:integer);
var
  s:ansistring;
  i,rc:integer;
begin
rc:=FormPeach.StringGridList.Rowcount;
if rc>1 then
   for i:=1 to rc-1 do
      begin
      if FormPeach.StringGridList.Cells[2,i]<>txt_list_isfolder then
         FormPeach.StringGridList.Cells[17,i]:=prefixfaz+padstrsort(c,i)
      else
         FormPeach.StringGridList.Cells[17,i]:=prefixdaz+padstrsort(c,i);
      end;
FormPeach.StringGridList.SortColRow(true,17);
end;

function smartsortable(s:ansistring):ansistring;
var
   fname,fext:string;
begin
result:=s;
if smartsortenabled=false then exit;
if result='' then exit;
if pos('.',result)<>0 then
   begin
   fname:=extractfilename(result);
   cutextension(fname);
   fext:=extractfileext(result);
   end
else
   begin
   fname:=result;
   fext:='';
   end;
fname:=smartsortstring(fname);
if fext<>'' then fext:=smartsortstring(fext);
if fext<>'' then result:=fname+''''+fext else result:=fname+''''; //some characters seems being sorted before space
end;

