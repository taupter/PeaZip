            begin
            destdir:=FormPeach.EditOpenIn.Text;//always refer to currently browsed path
            i:=cp_copy_filedir(clipcontent,destdir);
            end;
      if filecopying=false then
         if length(clipcontent)>0 then
            if (clipcontent[0,3]=txt_cut) or (clipmode=1) then
               if i=0 then
                  begin
                  prev_destdir:='';
                  setlength(clipcontent,0);
                  FormPeach.StringGridClipboard.Rowcount:=1;
                  FormPeach.StringGridClipboard.Autosizecolumns;
                  end;
      end;
end;

