   FormPeach.ComboBoxOverwrite.enabled:=false;
   FormPeach.LabelAdvExtZpaqBrZst.visible:=true;
   FormPeach.CheckBoxzpaqforce.visible:=true;
   end;
end;
end;

procedure updatecontent_ext;
var
   i,rc:integer;
begin
tfiles:=0;
tdirs:=0;
tsize:=0;
sizefreeint:=0;
//set hint overlay for extraction
   if FormPeach.StringGridExtract.RowCount>1 then hide_panelhintextract
   else FormPeach.PanelHintExtract.Visible:=true;
if FormPeach.StringGridExtract.RowCount=1 then
else
   begin
   rc:=FormPeach.StringGridExtract.RowCount-1;
   tfiles:=0;
   tdirs:=0;
   tsize:=0;
   for i:=1 to rc do
      begin
      if FormPeach.StringGridExtract.Cells[2,i] <> txt_list_isfolder then tfiles:=tfiles+1
      else tdirs:=tdirs+1;
      try
         tsize:=tsize+strtoqword(FormPeach.StringGridExtract.Cells[12,i]);
      except
      end;
      FormPeach.StringGridExtract.Cells[11,i]:='0';
      end;
   end;
get_statuss(FormPeach.EditOutExtract.Text);
if extselall=true then
   begin
   try srcfilesize_multipart(FormPeach.EditOpenIn.Text,tsize); except tsize:=0; end;
   FormPeach.LabelStatusExDetails.Caption:='0 '+txt_dirs+' '+'1 '+txt_files+' '+nicenumber(inttostr(tsize),filesizebase);
   end
else
   FormPeach.LabelStatusExDetails.Caption:=inttostr(tdirs)+' '+txt_dirs+' '+inttostr(tfiles)+' '+txt_files+' '+nicenumber(inttostr(tsize),filesizebase);
FormPeach.labelstatusEx.Visible:=false;
FormPeach.labelstatusEx.Caption:=txt_3_1_workingdir+' '+FormPeach.ComboBoxWD.Caption+' '+FormPeach.LabelCustomWorkPath.Caption;
autosize_stringgrid2;
if FormPeach.StringGridExtract.RowCount>1 then FormPeach.StringGridExtract.Cells[11,1]:='1';
sizefreeint:=tsize;
case fun of
   'UNZPAQ': setextzpaqext(1);//zpaq extended options
   'UNBROTLI': setextzpaqext(3);//br zst extended options only
   'UNZSTD': setextzpaqext(3);//br zst extended options only
   else
   begin
   setextzpaqext(0);//no extended options
   if fun='FILEBROWSER' then
      begin
      for i:=1 to FormPeach.StringGridExtract.RowCount-1 do
         if (lowercase(FormPeach.StringGridExtract.Cells[2,i]) = '.zpaq') then
            begin
            if FormPeach.StringGridExtract.RowCount>2 then setextzpaqext(2) //all options
            else setextzpaqext(1);//zpaq extended options
            break;
            end;
      for i:=1 to FormPeach.StringGridExtract.RowCount-1 do
         if ((lowercase(FormPeach.StringGridExtract.Cells[2,i]) = '.br') or
            (lowercase(FormPeach.StringGridExtract.Cells[2,i]) = '.zst')) then
            begin
            if FormPeach.StringGridExtract.RowCount>2 then setextzpaqext(2) //all options
            else setextzpaqext(3);//br zst extended options only
            break;
            end;
      if FormPeach.StringGridExtract.RowCount=1 then setextzpaqext(2); //all options
      end;
   end;
   end;
end;

