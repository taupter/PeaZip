cl:=bin_name+' '+out_param+' '+in_param;
if validatecl(cl)<>0 then
   begin
   pMessageWarningOK(txt_2_7_validatecl+' '+cl);
   exit;
   end;
peapexecute(P,cl);
P.Free;
pMessageInfoOK(txt_done+' '+local_desktop+FormPeach.Edit1.text+'.theme.7z');
except
   pMessageErrorOK(txt_theme_create_error);
   exit;
end;
end;

