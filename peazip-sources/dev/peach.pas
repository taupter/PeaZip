   begin
   set_pimmersive;
   pimmersive:=1;
   end
else
   begin
   FormPeach.BorderStyle:=bsSizeable;
   FormPeach.WindowState:=wsMaximized;
   FormPeach.WindowState:=wsNormal;
   FormPeach.Left:=DLEFT;
   FormPeach.Top:=DTOP;
   FormPeach.Width:=DWIDTH;
   FormPeach.Height:=DHEIGTH;
   pimmersive:=0;
   end;
end;

