   for i:=1 to k-1 do
      begin
      FormPeach.StringGridExtract.Cells[11,FormPeach.StringGridExtract.Row]:='0';
      end;
   FormPeach.StringGridExtract.Repaint;
   for i:=1 to k-1 do
      begin
