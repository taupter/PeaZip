procedure savecopy;
var
   sin,sout:ansistring;
   P:TProcessUTF8;
begin
sin:='';
if fun='FILEBROWSER' then
   begin
   if FormPeach.ListViewBrowser.SelCount=1 then
      if FormPeach.StringGridList.Cells[16,FormPeach.StringGridList.Row]='1' then
         sin:=FormPeach.StringGridList.Cells[12,FormPeach.StringGridList.Row];
   end
else
   sin:=FormPeach.EditOpenIn.Caption;
sout:='';
if sin<>'' then
   begin
   FormPeach.SaveDialogAS.FileName:=ExtractFileName(sin);
   FormPeach.SaveDialogAS.InitialDir:=ExtractFilePath(sin);
   if FormPeach.SaveDialogAS.Execute then
      if FormPeach.SaveDialogAS.FileName<>'' then
         sout:=FormPeach.SaveDialogAS.FileName
      else exit
   else exit;
   end;
if sout<>'' then
   if sin<>sout then
      try
      //CopyFile(sin,sout);
      {$IFDEF MSWINDOWS}
      fileop_fromnamelist_single(sin,sout,2,1);
      {$ELSE}
      P:=tprocessutf8.Create(nil);
      P.Options := [poWaitOnExit];
      cl:='cp -p -r '+stringdelim(sin)+' '+stringdelim(sout);
      if validatecl(cl)<>0 then
         begin
         pMessageWarningOK(txt_2_7_validatecl+' '+cl);
         exit;
         end;
      peapexecute(P,cl);
      P.Free;
      {$ENDIF}
      except
      end;
end;

